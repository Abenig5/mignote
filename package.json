    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  },
